# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# In production: your Vercel URL (e.g. https://your-app.vercel.app).
# Required for the browser to reach the API directly (NEXT_PUBLIC_USE_PROXY=0).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── LLM / AI keys (optional) ──────────────────────────────────────────────────
# Narrative polish via OpenAI. Leave blank to skip.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Recommendations via Google Gemini. Leave blank to skip.
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash
GOOGLE_TIMEOUT_S=20

# ── Persistence (optional) ────────────────────────────────────────────────────
# Postgres connection string (Supabase-compatible). Leave blank to disable /sessions.
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=

# ── ASR / Whisper ─────────────────────────────────────────────────────────────
# Model checkpoint. Options: openai/whisper-tiny (fast), openai/whisper-base (more accurate).
ASR_MODEL=openai/whisper-tiny
# Preload Whisper at startup. Set false on Render free tier to avoid cold-start OOM.
PRELOAD_ASR=true
# Max seconds of audio fed to Whisper (trims long clips for faster responses).
MAX_ASR_SECONDS=40
ASR_CHUNK_LENGTH_S=15
ASR_STRIDE_LENGTH_S=4
ASR_LANGUAGE=en

# ── Runtime hardening ─────────────────────────────────────────────────────────
ENVIRONMENT=dev
# Set true to hard-fail startup when model artifacts are missing.
REQUIRE_MODELS=false
# Upper bound (seconds) for the full analysis pipeline.
REQUEST_TIMEOUT_S=180
# Timeout (seconds) for LLM narrative polish.
NARRATIVE_TIMEOUT_S=45

# ── Rate limiting ─────────────────────────────────────────────────────────────
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60

# ── Admin / testing ───────────────────────────────────────────────────────────
# Set a secret string to enable /assess?override_transcript=... for deterministic testing.
ADMIN_KEY=
# Never set true in production.
ALLOW_TRANSCRIPT_OVERRIDE=false

# ── Delivery insights (optional) ──────────────────────────────────────────────
# Enables tone/prosody/gaze analysis (adds ~0.5–2s latency).
ENABLE_DELIVERY_INSIGHTS=false
FIT_WEIGHT_DELIVERY=0.05
