# ── API connection ────────────────────────────────────────────────────────────
# Set to 0 for production (browser uploads directly to FastAPI, bypasses Vercel
# ~4.5 MB proxy limit). Set to 1 to route through the Next.js /api/py proxy.
NEXT_PUBLIC_USE_PROXY=0

# Public FastAPI base URL — used by the browser when NEXT_PUBLIC_USE_PROXY=0.
# Get this from your Render dashboard after the API is deployed.
# Example: https://final-round-api.onrender.com
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# Server-only FastAPI base URL — used by the Next.js proxy when NEXT_PUBLIC_USE_PROXY=1.
# Must NOT point back at your own Vercel URL (would create a loop).
BACKEND_URL=https://your-api.onrender.com

# ── Site metadata ─────────────────────────────────────────────────────────────
# Used for sitemap.xml and OG / canonical URLs. Use your real domain when available.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
